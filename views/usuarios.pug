doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Gestión de Usuarios Externos
    style.
      body { font-family: 'Segoe UI', Arial, sans-serif; margin: 40px; background-color: #f4f6f9; color: #333; }
      .container { max-width: 1000px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
      h1, h2 { color: #2c3e50; border-bottom: 2px solid #ecf0f1; padding-bottom: 8px; }
      .filter-section { background: #ebf3f9; padding: 20px; border-radius: 6px; margin-bottom: 30px; border-left: 5px solid #2ecc71; }
      label { font-weight: bold; display: block; margin-bottom: 8px; color: #2c3e50; }
      select { width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #bdc3c7; font-size: 16px; background-color: white; }
      table { width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 30px; }
      th, td { border: 1px solid #e0e0e0; padding: 12px; text-align: left; }
      th { background-color: #34495e; color: white; font-weight: 600; }
      tr:nth-child(even) { background-color: #f8f9fa; }
      .no-data { color: #7f8c8d; font-style: italic; text-align: center; padding: 20px; background: #fafafa; border: 1px dashed #ccc; border-radius: 4px; }
      .badge { display: inline-block; padding: 4px 8px; background: #2ecc71; color: white; border-radius: 4px; font-size: 12px; font-weight: bold; }
      .btn-back { display: inline-block; margin-top: 20px; padding: 10px 15px; background-color: #7f8c8d; color: white; text-decoration: none; border-radius: 4px; font-weight: bold; }
      .btn-back:hover { background-color: #95a5a6; }

  body
    div(class="container")
      h1 Control de Usuarios Externos y Vehículos
      p Bienvenido al sistema, <strong>#{usuario.nombre || usuario}</strong>

      //- SECCIÓN DE FILTRADO (Selector de Usuarios por Email)
      div(class="filter-section")
        form(method="GET" action="/usuarios/lista")
          label(for="select-usuario") 👥 Seleccionar Usuario Externo para ver sus Vehículos:
          select(id="select-usuario" name="email" onchange="this.form.submit()")
            option(value="") -- Selecciona un usuario por su Email --
            if listaUsuarios && listaUsuarios.length > 0
              each user in listaUsuarios
                if user.email == emailSeleccionado
                  option(value=user.email selected) #{user.nombre} - #{user.email} (Tel: #{user.telefono})
                else
                  option(value=user.email) #{user.nombre} - #{user.email} (Tel: #{user.telefono})
            else
              option(value="" disabled) No hay usuarios externos registrados

      //- SECCIÓN DETALLES DEL USUARIO SELECCIONADO
      if UserSeleccionado
        h2 📋 Datos del Usuario
        table
          thead
            tr
              th Nombre Completo
              th Correo Electrónico
              th Teléfono de Contacto
          tbody
            tr
              td <strong>#{UserSeleccionado.nombre}</strong>
              td #{UserSeleccionado.email}
              td #{UserSeleccionado.telefono}

        //- SECCIÓN DE VEHÍCULOS ASIGNADOS
        h2 🚗 Vehículos Asociados
        if autos && autos.length > 0
          table
            thead
              tr
                th Tipo
                th Modelo
                th Color
                th Placa
                th Estado en Sistema
            tbody
              each auto in autos
                tr
                  td #{auto.tipo}
                  td #{auto.modelo}
                  td #{auto.color}
                  td <strong>#{auto.placa}</strong>
                  td
                    span(class="badge") Activo
        else
          p(class="no-data") ℹ️ Este usuario no posee ningún vehículo vinculado a su correo electrónico en la base de datos.
      
      else
        p(class="no-data") 💡 Selecciona un usuario en el menú superior para desplegar su ficha de contacto y los vehículos que tiene vinculados.

      br
      a(href="/" class="btn-back") ⬅️ Volver al Panel Principal