doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Gestión de Usuarios Externos
    link(rel="stylesheet", href="/styles.css") //- Cambia "/estilos.css" por la ruta correcta de tu archivo CSS

  body
    header
      h1 Control de Usuarios Externos y Vehículos
      a(href="/" class="btn-logout") ⬅️ Volver al Panel

    div(class="container")
      p Bienvenido al sistema, <strong>#{usuario.nombre || usuario}</strong>

      //- SECCIÓN DE FILTRADO (Selector de Usuarios por Email)
      div(class="filter-section" style="border-left-color: #10b981;") //- Se usa un verde esmeralda en línea para diferenciarlo de vehículos
        form(method="GET" action="/usuarios/lista")
          label(for="select-usuario") 👥 Seleccionar Usuario Externo para ver sus Vehículos:
          select(id="select-usuario" name="email" onchange="this.form.submit()")
            option(value="") -- Selecciona un usuario por su Email --
            if listaUsuarios && listaUsuarios.length > 0
              each user in listaUsuarios
                if user.email == emailSeleccionado
                  option(value=user.email selected) #{user.nombre} - #{user.email} (Tel: #{user.telefono})
                else
                  option(value=user.email) #{user.nombre} - #{user.email} (Tel: #{user.telefono})
            else
              option(value="" disabled) No hay usuarios externos registrados

      //- SECCIÓN DETALLES DEL USUARIO SELECCIONADO
      if UserSeleccionado
        h2 📋 Datos del Usuario
        table
          thead
            tr
              th Nombre Completo
              th Correo Electrónico
              th Teléfono de Contacto
          tbody
            tr
              td <strong>#{UserSeleccionado.nombre}</strong>
              td #{UserSeleccionado.email}
              td #{UserSeleccionado.telefono}

        //- SECCIÓN DE VEHÍCULOS ASIGNADOS
        h2 🚗 Vehículos Asociados
        if autos && autos.length > 0
          table
            thead
              tr
                th Tipo
                th Modelo
                th Color
                th Placa
                th Estado en Sistema
            tbody
              each auto in autos
                tr
                  td #{auto.tipo}
                  td #{auto.modelo}
                  td #{auto.color}
                  td <strong>#{auto.placa}</strong>
                  td
                    span(class="badge" style="background-color: #10b981;") Activo
        else
          p(class="no-data") ℹ️ Este usuario no posee ningún vehículo vinculado a su correo electrónico en la base de datos.
      
      else
        p(class="no-data") 💡 Selecciona un usuario en el menú superior para desplegar su ficha de contacto y los vehículos que tiene vinculados.