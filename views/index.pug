doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Sistema de Taller mecánico
    link(rel="stylesheet", href="/styles.css")

  body
    header.main-header
      h1 Sistema de Gestión
      nav.navbar
        a.btn-logout(href="/logout") Cerrar Sesión

    main.container
      section.welcome-box
        //- Usamos el nombre del usuario logueado de la base de datos
        h2 ¡Hola, #{usuario.nombre}! 
        p Has ingresado correctamente al sistema. Desde aquí puedes comenzar a administrar tus vehículos y registros asociados de manera segura.

        
      section.dashboard
        h3 Acciones Rápidas
        .dashboard-shortcuts
        h2 Creacion
        div
          a.btn-primary(href="/usuarios/registro") Crear Usuario Externo
          a.btn-primary(href="/vehiculos/agregar") Añadir Vehiculos
        div
        h2 Gestion
        div
          a.btn-primary(href="/usuarios") Gestionar Usuarios Externos
          a.btn-primary(href="/vehiculos") Gestionar Vehículos
        a.btn-dashboard(href="/soporte/dashboard") Ver Chats de Soporte Externo.
        div

    footer
      p &copy; 2026 - Sistema de Control de Vehículos y Usuarios.