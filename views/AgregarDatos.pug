doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Registrar Datos - Taller
    style.
      body { font-family: 'Segoe UI', Arial, sans-serif; margin: 40px; background-color: #f4f6f9; color: #333; }
      .container { max-width: 600px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
      h1, h2 { color: #2c3e50; border-bottom: 2px solid #ecf0f1; padding-bottom: 8px; margin-top: 30px; }
      .form-group { margin-bottom: 15px; }
      label { font-weight: bold; display: block; margin-bottom: 5px; color: #34495e; }
      input, select, textarea { width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #bdc3c7; font-size: 15px; box-sizing: border-box; }
      textarea { resize: vertical; height: 80px; }
      .btn-submit { background-color: #2c3e50; color: white; border: none; padding: 12px 20px; border-radius: 4px; font-size: 16px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 10px; }
      .btn-submit:hover { background-color: #1a252f; }

  body
    div(class="container")

      h1 🚗 Registrar Nuevo Vehículo
      form(method="POST" action="/vehiculos")
        div(class="form-group")
          label(for="tipo") Tipo de Vehículo:
          select(id="tipo" name="tipo" required)
            option(value="Auto") Auto
            option(value="Camioneta") Camioneta
            option(value="Camión") Camión
            option(value="Moto") Moto
        
        div(class="form-group")
          label(for="modelo") Modelo / Año:
          input(type="text" id="modelo" name="modelo" placeholder="Ej: Hilux 2024" required)
        
        div(class="form-group")
          label(for="color") Color:
          input(type="text" id="color" name="color" placeholder="Ej: Blanco" required)
        
        div(class="form-group")
          label(for="placa") Placa (Única):
          input(type="text" id="placa" name="placa" placeholder="Ej: ABC123" required)
        
        button(type="submit" class="btn-submit") Guardar Vehículo

      h2 🛠️ Registrar Cambio / Reparación
      form(method="POST" action="/cambios")
        div(class="form-group")
          label(for="select-placa") Seleccionar Vehículo por Placa:
          select(id="select-placa" name="placa" required)
            option(value="") -- Selecciona una placa existente --
            if listaVehiculos && listaVehiculos.length > 0
              each auto in listaVehiculos
                option(value=auto.placa) #{auto.placa} - #{auto.tipo} #{auto.modelo}
            else
              option(value="" disabled) No hay vehículos en la base de datos

        div(class="form-group")
          label(for="tipoCambio") Tipo de Mantenimiento:
          select(id="tipoCambio" name="tipo" required)
            option(value="Cambio") Cambio de repuesto
            option(value="Arreglo") Arreglo / Reparación
            option(value="Revisión") Revisión General
        
        div(class="form-group")
          label(for="parte") Parte / Componente afectado:
          input(type="text" id="parte" name="parte" placeholder="Ej: Frenos delanteros" required)
        
        div(class="form-group")
          label(for="detalles") Detalles del Trabajo:
          textarea(id="detalles" name="detalles" placeholder="Describe el trabajo realizado..." required)
        
        div(class="form-group")
          label(for="encargado") Encargado / Mecánico:
          input(type="text" id="encargado" name="encargado" placeholder="Nombre del responsable" required)
        
        button(type="submit" class="btn-submit" style="background-color: #e67e22;") Guardar Historial